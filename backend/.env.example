# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=https://Inkverta.vercel.app
# Optional (comma-separated) additional allowed origins for CORS
# For production:
# CORS_ORIGINS=https://Inkverta.vercel.app,chrome-extension://*
# For local dev:
# CORS_ORIGINS=http://localhost:3000,chrome-extension://*

# Translation APIs
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
DEEPL_API_KEY=your_deepl_api_key_here

# File Storage
MAX_FILE_SIZE=50MB
UPLOAD_DIR=uploads
TEMP_DIR=temp

# OCR Configuration
OCR_LANGUAGE=eng+jpn+kor+chi_sim+chi_tra
OCR_PSM=6
OCR_OEM=3

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_KEYS=1000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_DELAY_AFTER=50
RATE_LIMIT_DELAY_MS=500

# Monitoring
LOG_LEVEL=info
HEALTH_CHECK_INTERVAL=30000

# SSL (Production)
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Database (Optional - for user management)
DATABASE_URL=postgresql://user:password@localhost:5432/comic_translator

# Redis (Optional - for advanced caching)
REDIS_URL=redis://localhost:6379

